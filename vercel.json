{
  "name": "sentiment-meter",
  "version": "2",
  "public": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://sentiment-meter-api.up.railway.app/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "build": {
    "command": "",
    "output_directory": "frontend"
  },
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}